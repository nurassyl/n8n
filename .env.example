# =====================================================================
# n8n.nurassyl.com — environment configuration TEMPLATE
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# --- Public hostname ---
DOMAIN=n8n.nurassyl.com
ACME_EMAIL=contact@nurassyl.com

# --- Timezone ---
GENERIC_TIMEZONE=Asia/Almaty
TZ=Asia/Almaty

# --- Postgres credentials ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=__generate_with__openssl_rand_hex_24__
POSTGRES_DB=n8n

# --- n8n encryption key ---
# CRITICAL: generate once with `openssl rand -hex 32`, never change after first
# run or all stored credentials in n8n become unreadable.
N8N_ENCRYPTION_KEY=__generate_with__openssl_rand_hex_32__

# --- n8n public URLs ---
N8N_HOST=n8n.nurassyl.com
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://n8n.nurassyl.com/
N8N_EDITOR_BASE_URL=https://n8n.nurassyl.com/

# --- Security / runtime ---
N8N_PROXY_HOPS=1
N8N_RUNNERS_ENABLED=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_LOG_LEVEL=info
NODE_ENV=production

# --- Basic auth disabled; first visit creates owner account in UI ---
N8N_BASIC_AUTH_ACTIVE=false

# --- mcp-excel OAuth 2.0 client (Claude.ai / ChatGPT Custom Connector) ---
# Client ID: arbitrary (e.g. "mcp-excel-claude-XXXX")
# Client Secret: generate with `openssl rand -hex 32`
MCP_EXCEL_OAUTH_CLIENT_ID=mcp-excel-claude-CHANGEME
MCP_EXCEL_OAUTH_CLIENT_SECRET=__generate_with__openssl_rand_hex_32__
