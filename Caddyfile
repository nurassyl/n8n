{
	email {$ACME_EMAIL}
	# Use prod ACME; comment out for staging tests:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
	encode zstd gzip

	# Larger uploads (Excel files etc.) — n8n default cap is fine,
	# but reverse-proxy must not bottleneck.
	request_body {
		max_size 100MB
	}

	# Custom MCP server for Claude.ai / ChatGPT — generic OneDrive Excel tools.
	# Streamable HTTP transport at /mcp-excel — Caddy strips the prefix.
	handle_path /mcp-excel* {
		reverse_proxy mcp-excel:3000 {
			flush_interval -1
		}
	}

	# Everything else goes to n8n. The `handle` wrapper makes this mutually
	# exclusive with the handle_path block above.
	handle {
		reverse_proxy n8n:5678 {
			header_up X-Real-IP {remote_host}
			# WebSocket / SSE support (MCP transport uses SSE)
			flush_interval -1
		}
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
